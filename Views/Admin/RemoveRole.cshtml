@using Microsoft.AspNetCore.Identity
@{
    ViewData["Title"] = "Remove Role";
    var users = ViewBag.Users as List<IdentityUser>;
    var roles = ViewBag.Roles as List<IdentityRole>;
}

<h1>Remove Role</h1>

<form asp-action="RemoveRole" method="post">
    <div class="form-group mb-3">
        <label>User</label>
        <select name="userEmail" class="form-control">
            @foreach (var user in users)
            {
                <option value="@user.Email">@user.Email</option>
            }
        </select>
    </div>

    <div class="form-group mb-3">
        <label>Role</label>
        <select name="roleName" class="form-control">
            @foreach (var role in roles)
            {
                <option value="@role.Name">@role.Name</option>
            }
        </select>
    </div>

    <button type="submit" class="btn btn-danger">Remove Role</button>
</form>

<div class="mt-3">
    <a asp-action="Index">Back to Dashboard</a>
</div>